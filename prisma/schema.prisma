generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  avatar        String?
  age           Int
  level         Int       @default(1)
  experience    Int       @default(0)
  coins         Int       @default(0)
  totalStars    Int       @default(0)
  parentMode    Boolean   @default(false)
  parentPin     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  dailyTasks        DailyTask[]
  checkIns          CheckIn[]
  rewards           Reward[]
  badges            UserBadge[]
  breakfastPlans    BreakfastPlan[]
  readingRecords    ReadingRecord[]
  streaks           Streak[]
  growthTree        GrowthTree?
  pets              Pet[]
}

model DailyTask {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  taskType    TaskType
  title       String
  description String?
  scheduledTime String?
  completed   Boolean  @default(false)
  completedAt DateTime?
  points      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, date, taskType])
  @@index([userId, date])
}

model CheckIn {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  streakDay Int
  bonusCoins Int     @default(0)
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
}

model Reward {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        RewardType
  title       String
  description String?
  points      Int
  unlocked    Boolean  @default(false)
  unlockedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([userId, unlocked])
}

model Badge {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  icon        String
  category    BadgeCategory
  requirement String
  points      Int
  createdAt   DateTime @default(now())

  users UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt  DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
}

model BreakfastPlan {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekDay     Int
  mainDish    String
  sideDish    String
  drink       String
  fruit       String
  isFavorite  Boolean  @default(false)
  completed   Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, weekDay])
  @@index([userId, weekDay])
}

model ReadingRecord {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  bookTitle   String
  pages       Int
  minutes     Int
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId, date])
}

model Streak {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskType     TaskType
  currentStreak Int     @default(0)
  bestStreak   Int      @default(0)
  lastCompletedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, taskType])
  @@index([userId])
}

model GrowthTree {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  level       Int      @default(1)
  experience  Int      @default(0)
  health      Int      @default(100)
  unlockedFeatures String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Pet {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  type        PetType
  level       Int      @default(1)
  experience  Int      @default(0)
  happiness   Int      @default(100)
  unlocked    Boolean  @default(false)
  unlockedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, unlocked])
}

enum TaskType {
  WAKE_UP
  BREAKFAST
  SCHOOL
  HOMEWORK
  ENGLISH
  MATH
  READING
  SLEEP
  EXERCISE
  FREE_TIME
}

enum RewardType {
  LEVEL_UP
  STREAK
  BADGE
  PET
  SPECIAL
}

enum BadgeCategory {
  ACHIEVEMENT
  HABIT
  LEARNING
  SOCIAL
  SPECIAL
}

enum PetType {
  CAT
  DOG
  RABBIT
  BIRD
  HAMSTER
  TURTLE
}
